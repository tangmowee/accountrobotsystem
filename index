<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RSC Financial Dashboard — กุมภาพันธ์ 2569</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --orange: #E85D04;
    --orange-light: #F48C06;
    --orange-dim: rgba(232,93,4,0.12);
    --dark: #0D0D0D;
    --dark2: #141414;
    --card: #1A1A1A;
    --border: rgba(255,255,255,0.07);
    --text: #F0EDE8;
    --muted: #888;
    --green: #2ECC71;
    --red: #E74C3C;
    --yellow: #F39C12;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--dark);
    color: var(--text);
    font-family: 'Sarabun', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* HEADER */
  .header {
    background: var(--dark2);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .logo-mark {
    width: 36px; height: 36px;
    background: var(--orange);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 14px;
    color: #fff;
    letter-spacing: 0;
  }
  .company-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--text);
  }
  .report-badge {
    background: var(--orange-dim);
    border: 1px solid var(--orange);
    color: var(--orange-light);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 2px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .header-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }

  /* NAV TABS */
  .nav-tabs {
    background: var(--dark2);
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    display: flex;
    gap: 0;
    overflow-x: auto;
  }
  .nav-tab {
    padding: 14px 20px;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }
  .nav-tab:hover { color: var(--text); }
  .nav-tab.active {
    color: var(--orange);
    border-bottom-color: var(--orange);
  }

  /* MAIN LAYOUT */
  .main { padding: 32px 40px; max-width: 1400px; margin: 0 auto; }

  /* SECTION */
  .section { display: none; animation: fadeIn 0.3s ease; }
  .section.active { display: block; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    color: var(--text);
    margin-bottom: 4px;
  }
  .section-sub {
    color: var(--muted);
    font-size: 13px;
    margin-bottom: 28px;
  }

  /* CARDS GRID */
  .cards-row {
    display: grid;
    gap: 16px;
    margin-bottom: 24px;
  }
  .cards-row.col-5 { grid-template-columns: repeat(5, 1fr); }
  .cards-row.col-4 { grid-template-columns: repeat(4, 1fr); }
  .cards-row.col-3 { grid-template-columns: repeat(3, 1fr); }
  .cards-row.col-2 { grid-template-columns: 1fr 1fr; }
  .cards-row.col-1-2 { grid-template-columns: 1fr 2fr; }
  .cards-row.col-2-1 { grid-template-columns: 2fr 1fr; }

  /* KPI CARD */
  .kpi {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 20px 22px;
    position: relative;
    overflow: hidden;
  }
  .kpi::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--orange);
  }
  .kpi.red::before { background: var(--red); }
  .kpi.green::before { background: var(--green); }
  .kpi.yellow::before { background: var(--yellow); }
  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .kpi-value {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 26px;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
    margin-bottom: 6px;
  }
  .kpi-value.lg { font-size: 32px; }
  .kpi-value.red { color: var(--red); }
  .kpi-value.green { color: var(--green); }
  .kpi-value.orange { color: var(--orange); }
  .kpi-note {
    font-size: 12px;
    color: var(--muted);
  }
  .kpi-sub {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }
  .badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 2px;
    letter-spacing: 0.5px;
    margin-top: 6px;
  }
  .badge.red { background: rgba(231,76,60,0.15); color: var(--red); border: 1px solid rgba(231,76,60,0.3); }
  .badge.green { background: rgba(46,204,113,0.12); color: var(--green); border: 1px solid rgba(46,204,113,0.3); }
  .badge.yellow { background: rgba(243,156,18,0.12); color: var(--yellow); border: 1px solid rgba(243,156,18,0.3); }
  .badge.orange { background: var(--orange-dim); color: var(--orange-light); border: 1px solid rgba(232,93,4,0.3); }

  /* CONTENT CARD */
  .content-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border);
  }
  .card-title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--text);
  }
  .card-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--orange);
    background: var(--orange-dim);
    padding: 2px 8px;
    border-radius: 2px;
  }

  /* TABLE */
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  th {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
  }
  td {
    padding: 10px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--text);
    vertical-align: top;
  }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,0.02); }
  .td-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    text-align: right;
  }
  .td-center { text-align: center; }
  .tfoot-row td {
    font-weight: 700;
    color: var(--orange-light);
    border-top: 1px solid var(--border);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
  }

  /* STATUS DOTS */
  .dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 6px; }
  .dot.red { background: var(--red); }
  .dot.yellow { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }
  .dot.green { background: var(--green); }
  .dot.orange { background: var(--orange); }

  /* CHART BAR */
  .bar-group { margin-bottom: 14px; }
  .bar-label {
    display: flex; justify-content: space-between;
    font-size: 12px; margin-bottom: 5px;
  }
  .bar-label span:first-child { color: var(--muted); }
  .bar-label span:last-child { font-family: 'IBM Plex Mono', monospace; color: var(--text); }
  .bar-track {
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    height: 6px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--orange);
    transition: width 1s ease;
  }
  .bar-fill.red { background: var(--red); }
  .bar-fill.green { background: var(--green); }
  .bar-fill.yellow { background: var(--yellow); }

  /* DIVIDER */
  .divider { border: none; border-top: 1px solid var(--border); margin: 20px 0; }

  /* HIGHLIGHT ROW */
  .highlight-row { background: rgba(232,93,4,0.06) !important; }
  .highlight-row td { color: var(--orange-light) !important; }

  /* WATERMARK */
  .watermark {
    position: fixed;
    bottom: 20px; right: 24px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: rgba(255,255,255,0.08);
    pointer-events: none;
  }

  /* OVERVIEW SUMMARY BAR */
  .summary-bar {
    background: var(--orange-dim);
    border: 1px solid rgba(232,93,4,0.25);
    border-radius: 4px;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    font-size: 13px;
  }
  .summary-bar .icon { font-size: 18px; }
  .summary-bar strong { color: var(--orange-light); }

  /* INCOME vs EXPENSE visual */
  .income-bar-wrapper { margin: 16px 0; }
  .income-row { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; }
  .income-row-label { width: 120px; font-size: 12px; color: var(--muted); flex-shrink: 0; }
  .income-row-bar { flex: 1; height: 22px; background: rgba(255,255,255,0.04); border-radius: 2px; overflow: hidden; position: relative; }
  .income-row-fill { height: 100%; border-radius: 2px; display: flex; align-items: center; padding-left: 8px; font-family: 'IBM Plex Mono', monospace; font-size: 11px; font-weight: 600; color: #fff; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .cards-row.col-5 { grid-template-columns: repeat(2, 1fr); }
    .cards-row.col-4 { grid-template-columns: repeat(2, 1fr); }
    .cards-row.col-3 { grid-template-columns: 1fr 1fr; }
    .cards-row.col-1-2, .cards-row.col-2-1 { grid-template-columns: 1fr; }
    .main { padding: 20px; }
    .header, .nav-tabs { padding: 0 20px; }
  }

  /* CASHFLOW TABLE */
  .cf-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
    min-width: 1100px;
  }
  .cf-table thead {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #1f1f1f;
  }
  .cf-table th {
    background: #1f1f1f;
    color: var(--muted);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    padding: 10px 10px;
    text-align: right;
    border-bottom: 2px solid var(--border);
    white-space: nowrap;
  }
  .cf-table th.sticky-col, .cf-table td.sticky-col {
    position: sticky;
    left: 0;
    background: inherit;
    z-index: 5;
    text-align: left;
    min-width: 220px;
    max-width: 240px;
  }
  .cf-table thead th.sticky-col { z-index: 15; background: #1f1f1f; }
  .cf-table .feb-col {
    background: rgba(252,231,4,0.06) !important;
    border-left: 1px solid rgba(252,231,4,0.2);
    border-right: 1px solid rgba(252,231,4,0.2);
  }
  .cf-table thead th:nth-child(3) { /* feb header */
    color: #F5C518;
    background: rgba(252,231,4,0.08);
  }
  .cf-table .section-row {
    background: rgba(232,93,4,0.1);
  }
  .cf-table .section-row td {
    color: var(--orange);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 8px 12px;
  }
  .cf-table .spacer-row td { height: 6px; background: rgba(255,255,255,0.01); }
  .cf-table .data-row { background: var(--dark2); }
  .cf-table .data-row:hover td { background: rgba(255,255,255,0.03); }
  .cf-table .subtotal-row { background: rgba(255,255,255,0.04); }
  .cf-table .subtotal-row td { font-weight: 700; color: var(--text); border-top: 1px solid var(--border); }
  .cf-table .total-row { background: rgba(232,93,4,0.07); }
  .cf-table .total-row td { font-weight: 700; font-size: 13px; color: var(--orange-light); border-top: 2px solid rgba(232,93,4,0.3); }
  .cf-table .label-col {
    color: var(--text);
    padding: 8px 12px;
    font-size: 12px;
    border-right: 1px solid var(--border);
    background: var(--card);
  }
  .cf-table .data-row .label-col { padding-left: 20px; color: var(--muted); font-size: 11.5px; }
  .cf-table .num-col {
    text-align: right;
    padding: 8px 10px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    white-space: nowrap;
    color: var(--text);
    border-bottom: 1px solid rgba(255,255,255,0.02);
  }
  .cf-table .total-col {
    border-left: 2px solid var(--border);
    background: rgba(255,255,255,0.02);
    font-weight: 700;
  }
  .cf-table .neg { color: var(--red) !important; }

</style>
</head>
